PORT=5000
CLIENT_ORIGIN=http://localhost:5173

JWT_SECRET=replace_with_a_long_random_secret

DB_USER=your_sql_admin
DB_PASSWORD=your_sql_password
DB_SERVER=your-server.database.windows.net
DB_NAME=LiveChatDB
DB_PORT=1433

AZURE_STORAGE_CONNECTION_STRING=your_storage_connection_string
AZURE_STORAGE_CONTAINER=chatfiles

WEB_PUBSUB_CONNECTION_STRING=your_web_pubsub_connection_string
WEB_PUBSUB_HUB=livechat
WEB_PUBSUB_CLIENT_ENDPOINT=https://YOUR_SERVICE.webpubsub.azure.com
WEB_PUBSUB_CLIENT_PATH=/clients/socketio/hubs/livechat